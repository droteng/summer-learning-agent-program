# Copy this file to .env.local and fill in real values for production.
# All LLM keys are optional — without them the app uses the deterministic
# mock provider, which produces lower-quality but free, offline-capable output.

# === App identity ===

# Used by /api/health and the printable report header.
APP_NAME=learning-squad.ai
APP_VERSION=0.1.0
# Public URL for the deployed app. Used by OpenRouter analytics + report links.
APP_URL=https://learning-squad.ai

# Run mode. Affects safety warnings, observability defaults, and config strictness.
# Possible values: development | production | test
NODE_ENV=development

# === LLM providers ===

# Primary provider. Anthropic direct gives the best prompt caching (90% off
# cached input) and Batch API discount (50% off) for async work.
ANTHROPIC_API_KEY=

# Challenger / fallback provider. Lets the router reach Gemini Flash-Lite,
# DeepSeek, Llama and other floor-priced models for the cheap tier.
OPENROUTER_API_KEY=

# Sent to OpenRouter for analytics/leaderboards. Optional.
LLM_APP_URL=https://learning-squad.ai
LLM_APP_TITLE=learning-squad.ai

# === Cost controls ===

# Per-child monthly token budget. When exhausted, the app falls back to the
# deterministic mock provider for the rest of the month and shows parents a
# "classic mode" notice. Acts as a runaway-cost circuit breaker.
LLM_MONTHLY_TOKEN_CAP=250000

# Force every call down to the cheapest tier ("cheap"). Set this if you spot
# an unexpected cost spike. Possible values: cheap | tutor | reasoning | safety | async
# Leave empty to let the router decide per task.
LLM_TIER_OVERRIDE=

# Force a specific provider regardless of tier. Useful for A/B tests.
# Possible values: anthropic | openrouter | mock
LLM_PROVIDER_OVERRIDE=

# Set to "1" to silence the structured llm_call stdout events (useful in CI).
LLM_TELEMETRY_SILENT=

# === Billing (Stripe) ===

# Server-side Stripe secret key. Without this, the billing UI shows a
# "billing not configured" notice and free tier is the only plan available.
STRIPE_SECRET_KEY=

# Webhook signing secret from the Stripe dashboard. Required for the
# /api/billing/webhook endpoint to verify events.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the four offered SKUs. Create them in the Stripe
# dashboard, then paste here. Without these, the corresponding plan/cadence
# combo is unavailable.
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=
STRIPE_PRICE_FAMILY_PLUS_MONTHLY=
STRIPE_PRICE_FAMILY_PLUS_YEARLY=

# === Database ===

# Connection string. When unset, the app uses node:sqlite at data/local.sqlite,
# which is fine for local dev but ephemeral on serverless production deploys.
# For Vercel + Supabase or Vercel + Neon, paste the full connection string.
# Examples:
#   postgres://user:pass@host:5432/db?sslmode=require
#   postgresql://...
DATABASE_URL=

# === Observability ===

# Sentry DSN for server-side error capture. Strongly recommended in production.
# When empty, the observability shim emits structured stderr lines instead.
SENTRY_DSN=

# PostHog product analytics. When empty, events go to structured stdout.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Set to "1" to silence the observability shim entirely (useful in tests).
OBSERVABILITY_SILENT=
