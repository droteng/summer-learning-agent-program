# Copy this file to .env.local and fill in real values for production.
# All LLM keys are optional — without them the app uses the deterministic
# mock provider, which produces lower-quality but free, offline-capable output.

# === App identity ===

# Used by /api/health and the printable report header.
APP_NAME=learning-squad.ai
APP_VERSION=0.1.0
# Public URL for the deployed app. Used by OpenRouter analytics + report links.
APP_URL=https://learning-squad.ai

# Run mode. Affects safety warnings, observability defaults, and config strictness.
# Possible values: development | production | test
NODE_ENV=development

# === LLM providers ===

# Primary provider. Anthropic direct gives the best prompt caching (90% off
# cached input) and Batch API discount (50% off) for async work.
ANTHROPIC_API_KEY=

# Challenger / fallback provider. Lets the router reach Gemini Flash-Lite,
# DeepSeek, Llama and other floor-priced models for the cheap tier.
OPENROUTER_API_KEY=

# Sent to OpenRouter for analytics/leaderboards. Optional.
LLM_APP_URL=https://learning-squad.ai
LLM_APP_TITLE=learning-squad.ai

# === Cost controls ===

# Per-child monthly token budget. When exhausted, the app falls back to the
# deterministic mock provider for the rest of the month and shows parents a
# "classic mode" notice. Acts as a runaway-cost circuit breaker.
LLM_MONTHLY_TOKEN_CAP=250000

# Force every call down to the cheapest tier ("cheap"). Set this if you spot
# an unexpected cost spike. Possible values: cheap | tutor | reasoning | safety | async
# Leave empty to let the router decide per task.
LLM_TIER_OVERRIDE=

# Force a specific provider regardless of tier. Useful for A/B tests.
# Possible values: anthropic | openrouter | mock
LLM_PROVIDER_OVERRIDE=

# Set to "1" to silence the structured llm_call stdout events (useful in CI).
LLM_TELEMETRY_SILENT=

# === Image generation (optional but recommended for production polish) ===

# Google Gemini 2.5 Flash Image ("nano-banana"). Default primary provider.
# Get a key at https://ai.google.dev/. ~$0.039 per image.
GOOGLE_API_KEY=

# OpenAI gpt-image-1. Strong text rendering, more expensive (~$0.04-0.17/img).
OPENAI_API_KEY=

# Replicate token for Flux Schnell (cheapest, ~$0.003/img) or Flux Pro.
REPLICATE_API_TOKEN=
FLUX_VARIANT=schnell

# Ideogram v2 — best when the image needs readable text inside it
# (vocab cards, labeled diagrams). ~$0.08/img.
IDEOGRAM_API_KEY=

# Monthly budget for image generation in cents. When exhausted, the agent
# falls back to the deterministic SVG mock for the rest of the month.
# Default: 5000 = $50/month.
IMAGE_MONTHLY_BUDGET_CENTS=5000

# === Founder's Book ===

# Public URL of the uploaded "Leo and The Game Squad" PDF on Vercel Blob.
# Upload via: node scripts/upload-book.js <path-to-pdf>
# Without this, the /api/book-download endpoint returns 503 ("book not
# configured") and the parent dashboard shows the subscribe-CTA fallback.
BOOK_PDF_BLOB_URL=

# Required only when running scripts/upload-book.js locally. Get from
# Vercel → Storage → your Blob store → connect to project.
BLOB_READ_WRITE_TOKEN=

# === Transactional email (verification + password reset) ===

# Resend API key. Sign up at https://resend.com (free tier: 3,000/mo).
# When empty, signup + reset emails are logged to stderr instead of
# sent — fine for local dev; the link shows up in the dev server log.
RESEND_API_KEY=

# Sender address Resend will use. The domain must be verified in your
# Resend account. Until you verify drsparkacademy.com, set to:
#   onboarding@resend.dev    (Resend's sandbox; test inbox only)
# Once verified, switch to e.g.:
#   "Dr. Spark Academy <no-reply@drsparkacademy.com>"
EMAIL_FROM=

# === Billing (Stripe) ===

# Server-side Stripe secret key. Without this, the billing UI shows a
# "billing not configured" notice and free tier is the only plan available.
STRIPE_SECRET_KEY=

# Webhook signing secret from the Stripe dashboard. Required for the
# /api/billing/webhook endpoint to verify events.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the six offered SKUs (2 tiers × 3 cadences).
# Create them in the Stripe dashboard, then paste here. Without these,
# the corresponding plan/cadence combo is unavailable.
#
# Summer Pass is a ONE-TIME price (Stripe: "One time" billing). Monthly
# and Yearly are RECURRING prices (Stripe: "Recurring" → Monthly / Yearly).
STRIPE_PRICE_FAMILY_SUMMER=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=
STRIPE_PRICE_FAMILY_PLUS_SUMMER=
STRIPE_PRICE_FAMILY_PLUS_MONTHLY=
STRIPE_PRICE_FAMILY_PLUS_YEARLY=

# === Database ===

# Connection string. When unset, the app uses node:sqlite at data/local.sqlite,
# which is fine for local dev but ephemeral on serverless production deploys.
# For Vercel + Supabase or Vercel + Neon, paste the full connection string.
# Examples:
#   postgres://user:pass@host:5432/db?sslmode=require
#   postgresql://...
DATABASE_URL=

# === Observability ===

# Sentry DSN for server-side error capture. Strongly recommended in production.
# When empty, the observability shim emits structured stderr lines instead.
# In Sentry, create a new Project ("learning-squad") under your existing
# org, then paste its DSN here.
SENTRY_DSN=

# Public Sentry DSN exposed to the browser bundle for client-side error
# capture. Usually the same value as SENTRY_DSN but prefixed for Next.js
# to inline it.
NEXT_PUBLIC_SENTRY_DSN=

# Required only for source-map uploads in CI builds. Leave empty locally.
# Get them from the Sentry project settings → Client Keys + Auth Tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog product analytics. When empty, events go to structured stdout.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Set to "1" to silence the observability shim entirely (useful in tests).
OBSERVABILITY_SILENT=
